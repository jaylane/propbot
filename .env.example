# Discord Bot Credentials
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id

# OpenAI (for bet slip image parsing via /track)
OPENAI_API_KEY=your-openai-api-key

# Encryption key for user Odds API keys (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# Database path
DATABASE_PATH=./data/propbot.db

# Optional: Default monitoring interval in minutes (default: 5)
MONITOR_INTERVAL_MINUTES=5
